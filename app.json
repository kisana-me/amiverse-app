{
  "expo": {
    "name": "Amiverse",
    "slug": "amiverse",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "amiverse",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "icon": "./assets/images/android-icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#3B3B3B",
        "foregroundImage": "./assets/images/android-icon-tp.png",
        "backgroundImage": "./assets/images/icon-bg.png",
        "monochromeImage": "./assets/images/android-icon-mc.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [],
      "package": "net.amiverse"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "画像を選択するために写真へのアクセスを許可してください。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon-tp.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#3B3B3B",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-web-browser",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ce0021b-bcb8-4500-98f9-dd55de1d1f0c"
      }
    }
  }
}
