{
  "expo": {
    "name": "Amiverse",
    "slug": "amiverse",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "amiverse",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "net.amiverse",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/images/android-icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#3B3B3B",
        "foregroundImage": "./assets/images/android-icon-tp.png",
        "backgroundImage": "./assets/images/icon-bg.png",
        "monochromeImage": "./assets/images/android-icon-mc.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [],
      "package": "net.amiverse"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "投稿への画像添付、プロフィールのアイコン・バナー変更のために写真へのアクセスを使用します。アップロードした画像は一般公開され、誰でも閲覧できる状態になります。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon-tp.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#3B3B3B",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-web-browser",
      "expo-video",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "あなたに合わせた情報・広告の表示、および効果測定のために、他社アプリやWebサイトをまたいだデータ追跡を求めています。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ce0021b-bcb8-4500-98f9-dd55de1d1f0c"
      }
    }
  }
}
